{
  "name": "valor-travel-mcp",
  "version": "1.0.0",
  "description": "The simplest no-auth travel MCP for AI agents — real-time flights, price calendars, affiliate booking links",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute valor-travel-db --file=./schema.sql --remote",
    "db:init:local": "wrangler d1 execute valor-travel-db --file=./schema.sql --local",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "agents": "^0.0.87",
    "hono": "^4.7.10",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250327.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.14.0"
  }
}
